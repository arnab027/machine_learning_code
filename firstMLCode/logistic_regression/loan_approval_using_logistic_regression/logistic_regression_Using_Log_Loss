"""
Logistic Regression using Log Loss (Cross-Entropy) with Gradient Descent.

This module implements logistic regression for binary classification using
log loss minimization via gradient descent. It's mathematically equivalent
to MLE but uses modern optimization terminology and numerical stability.

Advantages of Log Loss:
- Better numerical stability (no product underflow)
- Standard in modern deep learning frameworks
- Easier to scale to large datasets
- Consistent with automatic differentiation

Mathematical Model:
    - Linear combination: z = b0 + b1 * X
    - Prediction: ŷ = sigmoid(z) = 1 / (1 + e^(-z))
    - Log Loss: L = -[y*log(ŷ) + (1-y)*log(1-ŷ)]
    - Objective: Minimize L using gradient descent

Example:
    >>> from logistic_regression_logloss import LogisticRegressionLogLoss
    >>> X = np.array([600, 700, 750])
    >>> y = np.array([0, 1, 1])
    >>> model = LogisticRegressionLogLoss(learning_rate=0.01, epochs=1000)
    >>> model.fit(X, y)
    >>> predictions = model.predict(np.array([650, 725, 780]))
"""

import logging
from typing import Optional
import numpy as np
import pandas as pd

# Configure logging
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(levelname)s - %(message)s'
)
logger = logging.getLogger(__name__)

# Configuration constants
DEFAULT_LEARNING_RATE = 0.01  # Smaller for gradient descent
DEFAULT_EPOCHS = 1000
PRINT_INTERVAL = 100
EPSILON = 1e-10  # Prevents log(0) in loss calculation
CONVERGENCE_THRESHOLD = 1e-6  # For early stopping


class StandardScaler:
    """
    Standardize features by removing mean and scaling to unit variance.
    
    Uses Z-score normalization: (X - mean) / std
    """
    
    def __init__(self) -> None:
        """Initialize the scaler."""
        self.mean: Optional[float] = None
        self.std: Optional[float] = None
    
    def fit(self, X: np.ndarray) -> 'StandardScaler':
        """
        Fit the scaler on training data.
        
        Parameters:
            X (np.ndarray): Input features
        
        Returns:
            StandardScaler: Fitted scaler (self)
        """
        self.mean = np.mean(X)
        self.std = np.std(X)
        if self.std == 0:
            self.std = 1  # Prevent division by zero
        return self
    
    def transform(self, X: np.ndarray) -> np.ndarray:
        """
        Transform data using fitted mean and std.
        
        Parameters:
            X (np.ndarray): Input features
        
        Returns:
            np.ndarray: Normalized features
        """
        if self.mean is None or self.std is None:
            raise RuntimeError("Scaler must be fitted before transforming")
        return (X - self.mean) / self.std
    
    def fit_transform(self, X: np.ndarray) -> np.ndarray:
        """
        Fit and transform in one step.
        
        Parameters:
            X (np.ndarray): Input features
        
        Returns:
            np.ndarray: Normalized features
        """
        return self.fit(X).transform(X)


class LogisticRegressionLogLoss:
    """
    Logistic Regression classifier using Log Loss (Cross-Entropy) Loss.
    
    This class implements binary logistic regression using gradient descent to minimize
    the log loss function. Mathematically equivalent to MLE but uses modern optimization.
    
    Key Differences from MLE:
    - Uses GRADIENT DESCENT (subtract) instead of gradient ascent (add)
    - Minimizes log loss instead of maximizing likelihood
    - Better numerical stability with large datasets
    
    Features:
    - Feature normalization for improved convergence
    - Convergence monitoring with early stopping
    - Numerical stability with clipping
    - Tracking of loss history for visualization
    
    Mathematical Model:
        - Linear combination: z = b0 + b1 * X
        - Prediction: ŷ = sigmoid(z) = 1 / (1 + e^(-z))
        - Log Loss: L = -[y*log(ŷ) + (1-y)*log(1-ŷ)]
    
    Attributes:
        learning_rate (float): Step size for gradient descent (alpha).
        epochs (int): Number of training iterations.
        intercept (float): Learned intercept parameter (b0).
        weight (float): Learned weight parameter (b1).
        loss_history (list): Log loss values during training.
        scaler (StandardScaler): Feature scaler for normalization.
    """
    
    def __init__(
        self,
        learning_rate: float = DEFAULT_LEARNING_RATE,
        epochs: int = DEFAULT_EPOCHS
    ) -> None:
        """
        Initialize the LogisticRegressionLogLoss model.
        
        Parameters:
            learning_rate (float): Step size for gradient descent. Default: 0.01.
                Must be positive. Typical range: 0.001 to 0.1 for normalized features.
            epochs (int): Number of training iterations. Default: 1000.
                More epochs allow better convergence but increase training time.
        
        Raises:
            ValueError: If learning_rate <= 0 or epochs <= 0.
        """
        if learning_rate <= 0:
            raise ValueError(f"learning_rate must be positive, got {learning_rate}")
        if epochs <= 0:
            raise ValueError(f"epochs must be positive, got {epochs}")
        
        self.learning_rate = learning_rate
        self.epochs = epochs
        self.intercept: Optional[float] = None
        self.weight: Optional[float] = None
        self.loss_history: list = []
        self.scaler = StandardScaler()
        self.converged_epoch: Optional[int] = None
    
    @staticmethod
    def sigmoid(z: np.ndarray) -> np.ndarray:
        """
        Sigmoid activation function.
        
        Maps any real-valued input to a probability between 0 and 1.
        Formula: σ(z) = 1 / (1 + e^(-z))
        
        Parameters:
            z (np.ndarray): Input values (can be scalar or array).
        
        Returns:
            np.ndarray: Sigmoid output in range [0, 1].
        """
        z_clipped = np.clip(z, -500, 500)
        return 1 / (1 + np.exp(-z_clipped))
    
    def _calculate_log_loss(
        self,
        y_true: np.ndarray,
        y_pred: np.ndarray
    ) -> float:
        """
        Calculate the log loss (cross-entropy loss).
        
        Log Loss Formula:
        L = -[1/n * Σ(y*log(ŷ) + (1-y)*log(1-ŷ))]
        
        Also called Binary Cross-Entropy Loss.
        
        Parameters:
            y_true (np.ndarray): True binary labels (0 or 1).
            y_pred (np.ndarray): Predicted probabilities [0, 1].
        
        Returns:
            float: Log loss value. Lower is better.
        
        Notes:
            - Clipped to prevent log(0)
            - Scaled by 1/n for per-sample loss
            - Negative because we minimize: -log(likelihood)
        """
        # Clip predictions to prevent log(0)
        y_pred = np.clip(y_pred, EPSILON, 1 - EPSILON)
        
        # Binary cross-entropy formula
        cross_entropy = -(y_true * np.log(y_pred) + (1 - y_true) * np.log(1 - y_pred))
        
        # Average over all samples
        mean_loss = np.mean(cross_entropy)
        
        return float(mean_loss)
    
    def fit(self, X: np.ndarray, y: np.ndarray, verbose: bool = True) -> 'LogisticRegressionLogLoss':
        """
        Train the logistic regression model using gradient descent with log loss.
        
        Key Steps:
        1. Validate input data
        2. Normalize features using Z-score standardization
        3. Initialize parameters (b0=0, b1=0)
        4. For each epoch:
           a) Compute predictions using sigmoid
           b) Calculate log loss
           c) Compute gradients (negative of MLE gradients)
           d) Update parameters using GRADIENT DESCENT (subtract)
           e) Check for convergence
        
        Parameters:
            X (np.ndarray): Feature values (1D array of shape (n_samples,)).
            y (np.ndarray): Binary labels (1D array of shape (n_samples,), values 0 or 1).
            verbose (bool): If True, print training progress. Default: True.
        
        Returns:
            LogisticRegressionLogLoss: Fitted model (self).
        
        Raises:
            ValueError: If X and y have different lengths or if y contains non-binary values.
        """
        # Input validation
        X = np.asarray(X, dtype=np.float64)
        y = np.asarray(y, dtype=np.float64)
        
        if X.ndim != 1 or y.ndim != 1:
            raise ValueError("X and y must be 1D arrays")
        if len(X) != len(y):
            raise ValueError(f"X and y must have same length, got {len(X)} and {len(y)}")
        if not np.all(np.isin(y, [0, 1])):
            raise ValueError("y must contain only binary values (0 or 1)")
        
        logger.info(f"Starting training with {len(X)} samples for {self.epochs} epochs")
        
        # Normalize features
        X_normalized = self.scaler.fit_transform(X)
        logger.info(
            f"Feature normalization: mean={self.scaler.mean:.2f}, "
            f"std={self.scaler.std:.2f}"
        )
        
        # Initialize parameters
        self.intercept = 0.0
        self.weight = 0.0
        self.loss_history = []
        self.converged_epoch = None
        
        if verbose:
            print(f"{'Epoch':<8} | {'b0':<12} | {'b1':<12} | {'Log Loss':<12} | {'Loss Change':<12}")
            print("-" * 65)
        
        # Gradient descent optimization
        for epoch in range(self.epochs):
            # ---- FORWARD PASS ----
            # Compute linear combination
            z = self.intercept + self.weight * X_normalized
            
            # Apply sigmoid activation
            y_pred = self.sigmoid(z)
            
            # ---- BACKWARD PASS (Gradient Computation) ----
            # Error term: difference between prediction and true label
            error = y_pred - y  # NOTE: This is DIFFERENT from MLE (y - y_pred)
            
            # Gradient for intercept
            grad_intercept = np.sum(error)
            
            # Gradient for weight
            grad_weight = np.sum(error * X_normalized)
            
            # ---- PARAMETER UPDATE (GRADIENT DESCENT) ----
            # Update using SUBTRACTION (descent, not ascent)
            # This minimizes log loss instead of maximizing likelihood
            self.intercept -= self.learning_rate * grad_intercept
            self.weight -= self.learning_rate * grad_weight
            
            # ---- CALCULATE AND TRACK LOSS ----
            loss = self._calculate_log_loss(y, y_pred)
            self.loss_history.append(loss)
            
            # ---- CHECK FOR CONVERGENCE ----
            if len(self.loss_history) > 1:
                # Loss change (should be negative = decreasing)
                loss_change = self.loss_history[-1] - self.loss_history[-2]
                
                # Converged if loss barely decreases and we're past warmup
                if abs(loss_change) < CONVERGENCE_THRESHOLD and epoch > 100:
                    if self.converged_epoch is None:
                        self.converged_epoch = epoch
                        if verbose:
                            print(f"\nConverged at epoch {epoch} with loss change {loss_change:.2e}")
                        break
            else:
                loss_change = 0.0
            
            # ---- PRINT PROGRESS ----
            if verbose and epoch % PRINT_INTERVAL == 0:
                print(
                    f"{epoch:<8} | {self.intercept:<12.6f} | "
                    f"{self.weight:<12.6f} | {loss:<12.6f} | {loss_change:<12.2e}"
                )
        
        logger.info(
            f"Training completed. Final weights - Intercept: {self.intercept:.6f}, "
            f"Weight: {self.weight:.6f}"
        )
        
        return self
    
    def predict_proba(self, X: np.ndarray) -> np.ndarray:
        """
        Predict probability of positive class.
        
        Parameters:
            X (np.ndarray): Feature values (1D array or scalar).
        
        Returns:
            np.ndarray: Predicted probabilities in range [0, 1].
        
        Raises:
            RuntimeError: If model has not been fitted yet.
        """
        if self.intercept is None or self.weight is None:
            raise RuntimeError("Model must be fitted before making predictions")
        
        X = np.asarray(X, dtype=np.float64)
        X_normalized = self.scaler.transform(X)
        z = self.intercept + self.weight * X_normalized
        return self.sigmoid(z)
    
    def predict(self, X: np.ndarray, threshold: float = 0.5) -> np.ndarray:
        """
        Predict binary class labels.
        
        Parameters:
            X (np.ndarray): Feature values (1D array or scalar).
            threshold (float): Classification threshold. Default: 0.5.
                Predictions >= threshold are classified as 1, else 0.
        
        Returns:
            np.ndarray: Predicted binary labels (0 or 1).
        """
        probabilities = self.predict_proba(X)
        return (probabilities >= threshold).astype(int)
    
    def get_params(self) -> dict:
        """
        Get learned model parameters.
        
        Returns:
            dict: Dictionary containing intercept, weight, and scaler statistics.
        """
        return {
            'intercept': self.intercept,
            'weight': self.weight,
            'feature_mean': self.scaler.mean,
            'feature_std': self.scaler.std,
            'final_loss': self.loss_history[-1] if self.loss_history else None
        }


def main() -> None:
    """
    Main function demonstrating logistic regression using log loss for loan approval.
    
    Uses credit score as feature to predict loan approval (binary classification).
    Compares log loss approach with expected results.
    """
    # Load and prepare data
    data = {
        'credit_score': [600, 700, 750],
        'loan_granted': [0, 1, 1]
    }
    df = pd.DataFrame(data)
    
    X = df['credit_score'].values
    y = df['loan_granted'].values
    
    logger.info(f"Dataset shape: X={X.shape}, y={y.shape}")
    logger.info(f"Feature range: [{X.min()}, {X.max()}]")
    logger.info(f"Class distribution: {np.bincount(y)}")
    
    # Train model using LOG LOSS (Gradient Descent)
    print("=" * 70)
    print("LOGISTIC REGRESSION WITH LOG LOSS (Gradient Descent)")
    print("=" * 70)
    print()
    
    model = LogisticRegressionLogLoss(learning_rate=0.01, epochs=1000)
    model.fit(X, y, verbose=True)
    
    # Display results
    params = model.get_params()
    print(f"\n{'='*60}")
    print(f"Final Log Loss Model Parameters:")
    print(f"  Intercept (b0):      {params['intercept']:.6f}")
    print(f"  Weight (b1):         {params['weight']:.6f}")
    print(f"  Feature Mean:        {params['feature_mean']:.2f}")
    print(f"  Feature Std:         {params['feature_std']:.2f}")
    if model.converged_epoch:
        print(f"  Converged at epoch:  {model.converged_epoch}")
    print(f"  Final Loss:          {params['final_loss']:.6f}")
    print(f"{'='*60}\n")
    
    # Make predictions on new data
    test_scores = np.array([620, 700, 780])
    predictions_prob = model.predict_proba(test_scores)
    predictions_class = model.predict(test_scores)
    
    print(f"{'Credit Score':<15} | {'Probability':<15} | {'Prediction':<15}")
    print("-" * 50)
    for score, prob, pred in zip(test_scores, predictions_prob, predictions_class):
        prediction_text = "APPROVED" if pred == 1 else "NOT APPROVED"
        print(f"{score:<15} | {prob:<15.4f} | {prediction_text:<15}")
    
    print("\n" + "=" * 70)
    print("KEY DIFFERENCES: Log Loss vs. MLE")
    print("=" * 70)
    print(f"Method              | MLE (Ascent)      | Log Loss (Descent)")
    print(f"{'─'*70}")
    print(f"Objective           | Maximize L        | Minimize -log(L)")
    print(f"Update Direction    | Add (↑)           | Subtract (↓)")
    print(f"Loss Function       | Likelihood        | Log Loss")
    print(f"Gradient Math       | y - ŷ             | ŷ - y")
    print(f"Final Model         | IDENTICAL         | IDENTICAL")
    print(f"{'='*70}\n")


if __name__ == "__main__":
    main()


"""
1. Error Term: Different Sign
MLE (Gradient Ascent):
error = y - y_pred  # True - Predicted
Log Loss (Gradient Descent):    
error = y - y_pred  # True - Predicted

2. Parameter Update: Addition vs. Subtraction
MLE:
self.intercept += self.learning_rate * grad_intercept  # ADD
self.weight += self.learning_rate * grad_weight        # ADD

Log Loss:

self.intercept -= self.learning_rate * grad_intercept  # SUBTRACT
self.weight -= self.learning_rate * grad_weight        # SUBTRACT

3. Loss Function Calculation:
MLE:
likelihood = ∏(ŷ^y * (1-ŷ)^(1-y))  # Product form
# Goal: Maximize (higher is better)

Log Loss:
log_loss = -mean(y*log(ŷ) + (1-y)*log(1-ŷ))
